# Bot service environment variables.
TELEGRAM_TOKEN=replace_with_real_token
APP_TELEGRAM_POLLING_ENABLED=false
APP_TELEGRAM_URL=http://127.0.0.1:65535/bot
APP_TELEGRAM_UPDATE_LISTENER_SLEEP=1s
APP_TELEGRAM_DEBUG=false

# Bot gRPC server
APP_BOT_GRPC_SERVER_PORT=9090

# Bot -> Scrapper transport
APP_SCRAPPER_MODE=grpc
APP_SCRAPPER_BASE_URL=http://localhost:8081
APP_SCRAPPER_GRPC_HOST=localhost
APP_SCRAPPER_GRPC_PORT=9091
APP_SCRAPPER_GRPC_DEADLINE=3s
APP_SCRAPPER_CONNECT_TIMEOUT=2s
APP_SCRAPPER_READ_TIMEOUT=5s
