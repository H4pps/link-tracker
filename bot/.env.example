# Bot service environment variables.
TELEGRAM_TOKEN=replace_with_real_token
APP_TELEGRAM_POLLING_ENABLED=false
APP_TELEGRAM_URL=http://127.0.0.1:65535/bot
APP_TELEGRAM_UPDATE_LISTENER_SLEEP=1s
APP_TELEGRAM_DEBUG=false

# Database (consumer idempotency store)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/link_tracker
SPRING_DATASOURCE_USERNAME=link_tracker
SPRING_DATASOURCE_PASSWORD=link_tracker
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Bot gRPC server
APP_BOT_GRPC_SERVER_PORT=9090

# Bot -> Scrapper transport
APP_SCRAPPER_MODE=grpc
APP_SCRAPPER_BASE_URL=http://localhost:8081
APP_SCRAPPER_GRPC_HOST=localhost
APP_SCRAPPER_GRPC_PORT=9091
APP_SCRAPPER_GRPC_DEADLINE=3s
APP_SCRAPPER_CONNECT_TIMEOUT=2s
APP_SCRAPPER_READ_TIMEOUT=5s

# Bot Kafka consumer
APP_KAFKA_ENABLED=true
APP_KAFKA_BOOTSTRAP_SERVERS=localhost:19092,localhost:19093,localhost:19094
APP_KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8085
APP_KAFKA_LINK_UPDATES_TOPIC=link-updates
APP_KAFKA_LINK_UPDATES_DLQ_TOPIC=link-updates-dlq
APP_KAFKA_CONSUMER_GROUP=link-tracker-bot
APP_KAFKA_MAX_ATTEMPTS=3
APP_KAFKA_RETRY_BACKOFF=1s
