# AI Agent service environment variables.

# Kafka transport
APP_KAFKA_ENABLED=true
APP_KAFKA_BOOTSTRAP_SERVERS=localhost:19092,localhost:19093,localhost:19094
APP_KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8085
APP_KAFKA_RAW_UPDATES_TOPIC=link.raw-updates
APP_KAFKA_PROCESSED_UPDATES_TOPIC=link.processed-updates
APP_KAFKA_RAW_UPDATES_DLQ_TOPIC=link.raw-updates-dlq
APP_KAFKA_CONSUMER_GROUP=ai-agent
APP_KAFKA_MAX_ATTEMPTS=3
APP_KAFKA_RETRY_BACKOFF=1s

# Filtering rules
APP_AI_AGENT_STOP_WORDS=spam,ads,promo
APP_AI_AGENT_EXCLUDED_AUTHORS=bot-user
APP_AI_AGENT_MIN_LENGTH=20

# Summarization (stub | ai)
APP_AI_AGENT_SUMMARIZATION_MODE=stub
APP_AI_AGENT_SUMMARIZATION_THRESHOLD=500

# Spring AI (only used when APP_AI_AGENT_SUMMARIZATION_MODE=ai).
# OpenAI-compatible endpoint; works with YandexGPT / HuggingFace / a local model.
# Use a real key via env. DO NOT KEEP SECRETS HERE.
APP_AI_OPENAI_BASE_URL=https://api.openai.com
APP_AI_OPENAI_API_KEY=replace_with_real_key
APP_AI_OPENAI_MODEL=gpt-4o-mini
