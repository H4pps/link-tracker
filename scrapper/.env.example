# PostgreSQL (local / docker compose)
POSTGRES_DB=link_tracker
POSTGRES_USER=link_tracker
POSTGRES_PASSWORD=link_tracker

# Scrapper datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/link_tracker
SPRING_DATASOURCE_USERNAME=link_tracker
SPRING_DATASOURCE_PASSWORD=link_tracker
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
APP_DATABASE_ACCESS_TYPE=SQL

# Scrapper Valkey list-links cache
APP_VALKEY_CLUSTER_NODES=localhost:17000,localhost:17001,localhost:17002
APP_VALKEY_TIMEOUT=2s
APP_CACHE_LIST_LINKS_ENABLED=true
APP_CACHE_LIST_LINKS_TTL=10m

# Scrapper external API credentials
GITHUB_TOKEN=replace_with_github_token
STACKOVERFLOW_KEY=replace_with_stackoverflow_key
STACKOVERFLOW_ACCESS_KEY=replace_with_stackoverflow_access_token

# Scrapper gRPC server
APP_SCRAPPER_GRPC_SERVER_PORT=9091

# Scrapper -> Bot HTTP
APP_BOT_MODE=kafka
APP_BOT_BASE_URL=http://localhost:8080
APP_BOT_GRPC_HOST=localhost
APP_BOT_GRPC_PORT=9090
APP_BOT_GRPC_DEADLINE=3s
APP_BOT_CONNECT_TIMEOUT=2s
APP_BOT_READ_TIMEOUT=5s

# Scrapper Kafka transport and outbox publisher
APP_KAFKA_BOOTSTRAP_SERVERS=localhost:19092,localhost:19093,localhost:19094
APP_KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8085
APP_KAFKA_RAW_UPDATES_TOPIC=link.raw-updates
APP_KAFKA_MAX_ATTEMPTS=3
APP_KAFKA_RETRY_BACKOFF=1s
APP_KAFKA_OUTBOX_BATCH_SIZE=100
APP_KAFKA_OUTBOX_PUBLISH_INTERVAL=5s

# Scrapper resilience settings
APP_RESILIENCE_RETRY_MAX_ATTEMPTS=3
APP_RESILIENCE_RETRY_BACKOFF=200ms
APP_RESILIENCE_RETRY_RETRYABLE_HTTP_STATUSES=500,502,503,504
APP_RESILIENCE_CIRCUIT_BREAKER_FAILURE_RATE_THRESHOLD=50
APP_RESILIENCE_CIRCUIT_BREAKER_SLIDING_WINDOW_SIZE=10
APP_RESILIENCE_CIRCUIT_BREAKER_MINIMUM_NUMBER_OF_CALLS=5
APP_RESILIENCE_CIRCUIT_BREAKER_PERMITTED_CALLS_IN_HALF_OPEN_STATE=2
APP_RESILIENCE_CIRCUIT_BREAKER_OPEN_STATE_DURATION=5s
APP_RESILIENCE_RATE_LIMIT_LIMIT_FOR_PERIOD=60
APP_RESILIENCE_RATE_LIMIT_LIMIT_REFRESH_PERIOD=1m
APP_RESILIENCE_RATE_LIMIT_TIMEOUT_DURATION=0ms

# Scheduler
APP_SCHEDULER_ENABLED=true
APP_SCHEDULER_INTERVAL=30s
APP_SCHEDULER_LINK_PAGE_SIZE=100
APP_SCHEDULER_WORKER_COUNT=1

# GitHub API client
APP_GITHUB_BASE_URL=https://api.github.com
APP_GITHUB_CONNECT_TIMEOUT=2s
APP_GITHUB_READ_TIMEOUT=5s

# StackOverflow API client
APP_STACKOVERFLOW_BASE_URL=https://api.stackexchange.com
APP_STACKOVERFLOW_CONNECT_TIMEOUT=2s
APP_STACKOVERFLOW_READ_TIMEOUT=5s
